# ============================================================
# Nocrato Health V2 — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env
# ============================================================

# --- Banco de Dados (PostgreSQL 16) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nocrato_health
DB_USER=nocrato
DB_PASSWORD=nocrato_secret

# --- JWT ---
# Gere com: openssl rand -hex 64
JWT_SECRET=troque-por-um-secret-seguro-em-producao
JWT_REFRESH_SECRET=troque-por-outro-secret-seguro-em-producao
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Resend (Email) ---
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=noreply@nocrato.com.br

# --- Evolution API (WhatsApp) ---
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE=nocrato-instance
EVOLUTION_WEBHOOK_TOKEN=your-webhook-validation-token

# --- OpenAI (módulo agent/ — gpt-4o-mini) ---
OPENAI_API_KEY=sk-your-openai-api-key

# --- App ---
NODE_ENV=development
PORT=3000
